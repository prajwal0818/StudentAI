# Server
PORT=5000
NODE_ENV=development

# MongoDB (overridden by docker-compose)
MONGODB_URI=mongodb://localhost:27017/studentai

# Redis (overridden by docker-compose)
REDIS_URL=redis://localhost:6379

# Sessions
SESSION_TTL=604800

# JWT — CHANGE THIS in production
JWT_SECRET=your_jwt_secret_here

# Groq (free tier via console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Google Gemini (embeddings only - free via aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here
EMBEDDING_MODEL=gemini-embedding-001

# Google OAuth (Gmail integration)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback
TOKEN_ENCRYPTION_KEY=generate_a_64_hex_char_string_here

# Logging
LOG_LEVEL=info
